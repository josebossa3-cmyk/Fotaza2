doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title= title || 'Fotaza2'
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
        link(rel="stylesheet" href="/css/style.css")
        link(rel="stylesheet" href="/css/modal.css")
        link(rel='icon' href='/favicon.png' type='image/png')
        block extra_head
    body.d-flex.flex-column(style="min-height: 100vh;")
        include partials/header.pug
        
        .container.mt-4.flex-grow-1
            - var flashMsgs = typeof messages !== 'undefined' ? messages : {}
            if flashMsgs.success_msg && flashMsgs.success_msg.length
                each m in flashMsgs.success_msg
                    .alert.alert-success.alert-dismissible.fade.show(role="alert")
                        = m
                        button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Close")
            
            if flashMsgs.error_msg && flashMsgs.error_msg.length
                each m in flashMsgs.error_msg
                    .alert.alert-danger.alert-dismissible.fade.show(role="alert")
                        = m
                        button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Close")
            
            block content
        
        include partials/footer.pug
        include partials/postModal.pug

        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
        script(src="/js/modal.js" defer)