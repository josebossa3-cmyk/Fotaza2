extends ../layout.pug

block content 
  .row.justify-content-end 
    .col-md-6.col-lg-5
      .card.shadow-sm.border-0.rounded-4
        .card-body.p-4.p-md-5.text-center
          i.bi.bi-box-arrow-right.display-1.text-danger.mb-3
          h3.text-danger Cerrar Sesión
          p.lead ¿Estás seguro de queres salir?
          form(action="/auth/logout" method="POST")
            .d-grid.gap-2
              button.btn.btn-danger(type="submit")
                i.bi.bi-check-circle.me-2
                | Si, cerrar sesión
              a.btn.btn-outline-secondary(href="/")
                i.bi.bi-arrow-left.me-2
                | Cancelar

