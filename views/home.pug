extends layout

block append extra_head
    link(rel="stylesheet" href="/css/Stylehome.css")

block content
    section.hero-section
        .hero-content
            p.hero-eyebrow Plataforma visual
            h1.hero-title
                | Fotaza 2 
                br
                em inspira
                |  al mundo
            .hero-actions
                
        .hero-floating-tags
            span.tag Fotografía
            span.tag Diseño
            span.tag Arte
            span.tag Arquitectura
            span.tag Moda

